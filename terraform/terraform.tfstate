            "name_prefix": "",
            "policy": "{\"Version\":\"2012-10-17\",\"Statement\":[{\"Action\":\"ecr:GetAuthorizationToken\",\"Effect\":\"Allow\",\"Resource\":\"*\"},{\"Action\":[\"ecr:UploadLayerPart\",\"ecr:PutImage\",\"ecr:InitiateLayerUpload\",\"ecr:GetDownloadUrlForLayer\",\"ecr:CompleteLayerUpload\",\"ecr:BatchGetImage\",\"ecr:BatchCheckLayerAvailability\"],\"Effect\":\"Allow\",\"Resource\":[\"arn:aws:ecr:ap-southeast-2:587601535321:repository/multicloud-devops-dev-service-b\",\"arn:aws:ecr:ap-southeast-2:587601535321:repository/multicloud-devops-dev-service-a\"]},{\"Action\":[\"logs:PutLogEvents\",\"logs:CreateLogStream\",\"logs:CreateLogGroup\"],\"Effect\":\"Allow\",\"Resource\":\"*\"},{\"Action\":[\"s3:PutObject\",\"s3:GetObject\",\"s3:GetBucketLocation\",\"s3:GetBucketAcl\"],\"Effect\":\"Allow\",\"Resource\":[\"arn:aws:s3:::multicloud-devops-dev-pipeline-artifacts-587601535321/*\",\"arn:aws:s3:::multicloud-devops-dev-pipeline-artifacts-587601535321\"]},{\"Action\":[\"ecs:UpdateService\",\"ecs:RegisterTaskDefinition\",\"ecs:ListTasks\",\"ecs:DescribeTasks\",\"ecs:DescribeTaskDefinition\",\"ecs:DescribeServices\"],\"Effect\":\"Allow\",\"Resource\":\"*\"},{\"Action\":[\"elasticloadbalancing:ModifyListener\",\"elasticloadbalancing:DescribeTargetHealth\",\"elasticloadbalancing:DescribeTargetGroups\",\"elasticloadbalancing:DescribeListeners\"],\"Effect\":\"Allow\",\"Resource\":\"*\"},{\"Action\":\"iam:PassRole\",\"Effect\":\"Allow\",\"Resource\":[\"arn:aws:iam::587601535321:role/multicloud-devops-dev-service-b-task-role\",\"arn:aws:iam::587601535321:role/multicloud-devops-dev-service-a-task-role\",\"arn:aws:iam::587601535321:role/multicloud-devops-dev-ecs-exec-role\"]}]}",
            "role": "multicloud-devops-dev-codebuild-role"
          },
